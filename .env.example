# Telegram
TELEGRAM_TOKEN=          # токен от @BotFather
TELEGRAM_CHAT_ID=        # твой chat_id (узнать через @userinfobot)
BOT_LANG=ru              # язык интерфейса: ru или en

# Настройки стратегии
MIN_APR_THRESHOLD=100    # минимальный APR для одиночного сигнала (%)
MIN_PAIR_APR=50          # минимальный нетто APR для сигнала о паре (%)
SCAN_INTERVAL_SECONDS=60 # как часто сканировать рынок
MIN_OPEN_INTEREST_USD=5000000  # минимум OI для фильтра
MIN_VOLUME_USD=50000     # минимальный дневной объём ($)
POSITION_SIZE_USD=100    # размер позиции по умолчанию ($)

# Backpack Exchange (Ed25519)
# Ключи генерируются в настройках Backpack: Settings → API Keys
BACKPACK_API_KEY=        # Base64 Ed25519 public key
BACKPACK_API_SECRET=     # Base64 Ed25519 private key seed

# Lighter DEX (ZK order book)
# Ключи генерируются на lighter.xyz → Settings → API Keys
LIGHTER_API_PRIVATE_KEY= # API приватный ключ
LIGHTER_API_KEY_INDEX=2  # индекс ключа (обычно 2)
LIGHTER_ACCOUNT_INDEX=0  # индекс аккаунта (обычно 0)

# Hyperliquid
# Приватный ключ ETH кошелька, которым управляешь аккаунтом
HYPERLIQUID_PRIVATE_KEY= # EVM приватный ключ (0x...)
WALLET_ADDRESS=          # EVM адрес кошелька (0x...)

# GRVT (Gravity)
# API ключ создаётся на app.grvt.io → Settings → API Keys
# GRVT_TRADING_ACCOUNT_ID — sub-account ID (видно в URL или настройках)
GRVT_API_KEY=
GRVT_PRIVATE_KEY=        # ETH приватный ключ для подписи ордеров (0x...)
GRVT_TRADING_ACCOUNT_ID= # Sub-account ID (числовой)

# Aster DEX
# API ключ создаётся на asterdex.com → Account → API Management
ASTER_API_KEY=
ASTER_API_SECRET=

# BitMart Futures
# Создай API ключ на BitMart Futures с правами Contract Trade
BITMART_API_KEY=
BITMART_API_SECRET=
BITMART_API_MEMO=

# Extended Exchange (StarkNet)
# Создай API ключ на extended.exchange → API Management
# Установи: pip install x10-python-trading-starknet
EXTENDED_API_KEY=
EXTENDED_PUBLIC_KEY=
EXTENDED_PRIVATE_KEY=
EXTENDED_VAULT_ID=0
