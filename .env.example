# Telegram
TELEGRAM_TOKEN=          # токен от @BotFather
TELEGRAM_CHAT_ID=        # твой chat_id (узнать через @userinfobot)

# Настройки стратегии
MIN_APR_THRESHOLD=100    # минимальный APR для одиночного сигнала (%)
MIN_PAIR_APR=50          # минимальный нетто APR для сигнала о паре (%)
SCAN_INTERVAL_SECONDS=60 # как часто сканировать рынок
MIN_OPEN_INTEREST_USD=5000000  # минимум OI для фильтра
MIN_VOLUME_USD=50000     # минимальный дневной объём ($)
POSITION_SIZE_USD=100    # размер позиции по умолчанию ($)

# Backpack Exchange (Ed25519)
BACKPACK_API_KEY=        # Base64 Ed25519 public key
BACKPACK_API_SECRET=     # Base64 Ed25519 private key seed

# Lighter DEX (ZK order book)
LIGHTER_API_PRIVATE_KEY= # API приватный ключ
LIGHTER_API_KEY_INDEX=2  # индекс ключа
LIGHTER_ACCOUNT_INDEX=0  # индекс аккаунта

# Hyperliquid
HYPERLIQUID_PRIVATE_KEY= # EVM приватный ключ
WALLET_ADDRESS=          # EVM адрес кошелька

# GRVT
GRVT_API_KEY=
GRVT_PRIVATE_KEY=

# Aster
ASTER_API_KEY=
ASTER_API_SECRET=
